# ===========================
# Local AI China 配置文件
# 复制此文件为 .env 并按需修改
# ===========================

# Open WebUI 密钥（随机字符串即可，用于 session 加密）
WEBUI_SECRET_KEY=your-random-secret-key-here

# 默认加载的模型
DEFAULT_MODELS=qwen2.5:7b

# 代理设置（国内网络下载模型时可能需要）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# Ollama 并发请求数（默认 1，可根据硬件调整）
# OLLAMA_NUM_PARALLEL=2

# 模型存储路径（默认 Docker volume）
# OLLAMA_MODELS=/path/to/your/models
